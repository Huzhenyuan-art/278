# ==============================================================================
# 前端环境变量配置
# ------------------------------------------------------------------------------
# 注意：Vite 环境变量必须以 VITE_ 开头才能在客户端代码中访问
# ==============================================================================

# 后端 API 基础地址
VITE_API_BASE_URL=http://localhost:5160

# 应用名称
VITE_APP_NAME=IT技术交流平台

# 版本号
VITE_APP_VERSION=1.0.0
