# ==============================================================================
# IT 技术交流平台 - 环境变量配置模板
# ------------------------------------------------------------------------------
# 使用说明：
# 1. 复制此文件为 .env 并根据实际环境修改
# 2. .env 文件已加入 .gitignore，不会提交到代码库
# 3. 所有变量均有默认值，可根据需要覆盖
# ==============================================================================

# ------------------------------------------------------------------------------
# 应用环境
# ------------------------------------------------------------------------------
# 可选值: development, test, production
NODE_ENV=development

# ------------------------------------------------------------------------------
# 后端服务配置
# ------------------------------------------------------------------------------
# 后端服务监听端口
BACKEND_PORT=5160

# JWT 密钥（生产环境必须修改为复杂随机字符串）
JWT_SECRET=your_super_secret_jwt_key_should_be_changed_in_production
# JWT 过期时间
JWT_EXPIRES_IN=24h

# ------------------------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------------------------
# 数据库主机地址
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=root
# 数据库名称
DB_NAME=it_platform

# ------------------------------------------------------------------------------
# 文件上传配置
# ------------------------------------------------------------------------------
# 上传文件最大大小（字节）
UPLOAD_MAX_SIZE=5242880
# 允许的文件类型
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,image/jpg

# ------------------------------------------------------------------------------
# 初始数据配置（首次启动时自动创建）
# ------------------------------------------------------------------------------
# 管理员账号
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_EMAIL=admin@example.com

# 普通测试用户账号
SEED_USER_USERNAME=user
SEED_USER_PASSWORD=user123
SEED_USER_EMAIL=user@example.com

# ------------------------------------------------------------------------------
# 前端配置
# ------------------------------------------------------------------------------
# 前端服务端口
FRONTEND_PORT=3160
# 后端 API 地址（前端构建时使用）
VITE_API_BASE_URL=http://localhost:5160
